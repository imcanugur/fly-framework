{
    "name": "imcanugur/fly-framework",
    "description": "Beautiful, Modern & Opinionated PHP Framework — Internal-First Runtime Platform",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Fly\\": "core/",
            "App\\": "app/"
        },
        "files": [
            "core/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php -S localhost:8080 -t public"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}